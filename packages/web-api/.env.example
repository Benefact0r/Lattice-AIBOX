# Lattice web API — devnet defaults.
# Copy to .env.local. The keypair this server uses is the "demo wallet"
# that pays for inference on behalf of website visitors.

PORT=3001
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json
USDC_MINT=D5FZsaY5C7TndjmZVMqokXTBzn9BZ2zvCQ6yekLofWkc
LATTICE_PROGRAM_ID=4yR7v2c23wrxgFzcbtocvMvVxucYQHGfSWczNW3FxV7T

# Comma-separated list of allowed origins (CORS). Use * for dev.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
