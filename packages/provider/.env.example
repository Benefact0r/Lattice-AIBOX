# Lattice provider node — local dev configuration
# Copy to .env.local and adjust per-machine.

# Solana RPC endpoint
SOLANA_RPC_URL=http://127.0.0.1:8899

# Path to provider's Solana wallet keypair (signs register_provider, receives payouts)
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# USDC mint address (devnet/mainnet) or test-mint on localnet
USDC_MINT=CitRoSzrAx2MtTGJkhq5gyksBbYcoAqXBh9hTspU6fcc

# Stake amount in USDC micro-units (6 decimals → 100 USDC = 100_000_000)
STAKE_AMOUNT=100000000

# Price provider charges per 1k tokens, in USDC micro-units (1 USDC = 1_000_000)
PRICE_PER_1K=1000

# Lattice program ID (matches declare_id! in lib.rs)
LATTICE_PROGRAM_ID=4yR7v2c23wrxgFzcbtocvMvVxucYQHGfSWczNW3FxV7T
